generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(255)
  slug               String   @unique @db.VarChar(255)
  roomType           String   @map("room_type") @db.VarChar(50)
  description        String?  @db.Text
  shortDescription   String?  @map("short_description") @db.VarChar(500)
  maxGuests          Int      @default(2) @map("max_guests")
  numBedrooms        Int      @default(1) @map("num_bedrooms")
  numBathrooms       Int      @default(1) @map("num_bathrooms")
  numBeds            Int      @default(1) @map("num_beds")
  area               Decimal? @db.Decimal(6, 1)
  address            String?  @db.Text
  district           String?  @db.VarChar(100)
  city               String   @default("Hà Nội") @db.VarChar(100)
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  basePrice          Decimal  @map("base_price") @db.Decimal(12, 0)
  cleaningFee        Decimal  @default(0) @map("cleaning_fee") @db.Decimal(12, 0)
  checkinTime        DateTime @default(dbgenerated("'14:00:00'")) @map("checkin_time") @db.Time
  checkoutTime       DateTime @default(dbgenerated("'12:00:00'")) @map("checkout_time") @db.Time
  minNights          Int      @default(1) @map("min_nights")
  maxNights          Int      @default(30) @map("max_nights")
  houseRules         String?  @map("house_rules") @db.Text
  cancellationPolicy String?  @map("cancellation_policy") @db.Text
  status             String   @default("active") @db.VarChar(20)
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  bookings     Booking[]
  blockedDates BlockedDate[]
  images       RoomImage[]
  amenities    RoomAmenity[]
  pricingRules PricingRule[]
  icalLinks    IcalLink[]

  @@index([status])
  @@index([roomType])
  @@index([slug])
  @@map("rooms")
}

model Booking {
  id             Int       @id @default(autoincrement())
  bookingCode    String    @unique @map("booking_code") @db.VarChar(20)
  roomId         Int       @map("room_id")
  guestName      String    @map("guest_name") @db.VarChar(255)
  guestPhone     String    @map("guest_phone") @db.VarChar(20)
  guestEmail     String?   @map("guest_email") @db.VarChar(255)
  guestNote      String?   @map("guest_note") @db.Text
  checkinDate    DateTime  @map("checkin_date") @db.Date
  checkoutDate   DateTime  @map("checkout_date") @db.Date
  numGuests      Int       @default(1) @map("num_guests")
  numNights      Int       @map("num_nights")
  baseTotal      Decimal   @map("base_total") @db.Decimal(12, 0)
  cleaningFee    Decimal   @default(0) @map("cleaning_fee") @db.Decimal(12, 0)
  discount       Decimal   @default(0) @map("discount") @db.Decimal(12, 0)
  totalAmount    Decimal   @map("total_amount") @db.Decimal(12, 0)
  priceBreakdown Json?     @map("price_breakdown") @db.JsonB
  status         String    @default("pending") @db.VarChar(20)
  source         String    @default("website") @db.VarChar(20)
  adminNote      String?   @map("admin_note") @db.Text
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamp
  canceledAt     DateTime? @map("canceled_at") @db.Timestamp
  cancelReason   String?   @map("cancel_reason") @db.VarChar(255)
  expiresAt      DateTime? @map("expires_at") @db.Timestamp
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp

  room     Room      @relation(fields: [roomId], references: [id])
  payments Payment[]

  @@index([roomId, checkinDate, checkoutDate])
  @@index([status])
  @@index([expiresAt])
  @@index([bookingCode])
  @@index([guestPhone])
  @@map("bookings")
}

model BlockedDate {
  id        Int      @id @default(autoincrement())
  roomId    Int      @map("room_id")
  date      DateTime @db.Date
  source    String   @db.VarChar(30)
  sourceRef String?  @map("source_ref") @db.VarChar(255)
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  room Room @relation(fields: [roomId], references: [id])

  @@unique([roomId, date, source])
  @@index([roomId, date])
  @@index([source])
  @@map("blocked_dates")
}

model Payment {
  id                 Int       @id @default(autoincrement())
  bookingId          Int       @map("booking_id")
  amount             Decimal   @db.Decimal(12, 0)
  method             String    @db.VarChar(30)
  vnpayTxnRef        String?   @map("vnpay_txn_ref") @db.VarChar(100)
  vnpayTransactionNo String?   @map("vnpay_transaction_no") @db.VarChar(100)
  vnpayResponseCode  String?   @map("vnpay_response_code") @db.VarChar(10)
  vnpayBankCode      String?   @map("vnpay_bank_code") @db.VarChar(20)
  vietqrTransactionId String?  @map("vietqr_transaction_id") @db.VarChar(100)
  status             String    @default("pending") @db.VarChar(20)
  paidAt             DateTime? @map("paid_at") @db.Timestamp
  rawResponse        Json?     @map("raw_response") @db.JsonB
  adminNote          String?   @map("admin_note") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamp

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([vnpayTxnRef])
  @@map("payments")
}

model RoomImage {
  id        Int      @id @default(autoincrement())
  roomId    Int      @map("room_id")
  url       String   @db.VarChar(500)
  altText   String?  @map("alt_text") @db.VarChar(255)
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@map("room_images")
}

model Admin {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  role         String   @default("admin") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamp

  @@map("admins")
}

model PricingRule {
  id            Int       @id @default(autoincrement())
  roomId        Int       @map("room_id")
  name          String?   @db.VarChar(255)
  ruleType      String    @map("rule_type") @db.VarChar(30)
  dateFrom      DateTime? @map("date_from") @db.Date
  dateTo        DateTime? @map("date_to") @db.Date
  dayOfWeek     Int[]?    @map("day_of_week")
  priceModifier Decimal   @map("price_modifier") @db.Decimal(12, 0)
  modifierType  String    @default("fixed") @map("modifier_type") @db.VarChar(10)
  priority      Int       @default(0)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamp

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@index([dateFrom, dateTo])
  @@map("pricing_rules")
}

model Setting {
  key         String   @id @db.VarChar(100)
  value       Json     @db.JsonB
  description String?  @db.VarChar(255)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamp

  @@map("settings")
}

model RoomAmenity {
  id       Int     @id @default(autoincrement())
  roomId   Int     @map("room_id")
  name     String  @db.VarChar(100)
  icon     String? @db.VarChar(50)
  category String  @default("general") @db.VarChar(50)

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@map("room_amenities")
}

model IcalLink {
  id           Int       @id @default(autoincrement())
  roomId       Int       @map("room_id")
  platform     String    @db.VarChar(50)
  importUrl    String?   @map("import_url") @db.Text
  exportUrl    String?   @map("export_url") @db.Text
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamp
  syncStatus   String    @default("idle") @map("sync_status") @db.VarChar(20)
  syncError    String?   @map("sync_error") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamp

  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId])
  @@map("ical_links")
}
